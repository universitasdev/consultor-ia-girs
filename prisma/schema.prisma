// prisma/schema.prisma

// 1. Configuración del proveedor de base de datos y la URL
datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // Conexión Pooler (para la aplicación)
  directUrl = env("DIRECT_URL") // Conexión Directa (para migraciones)
}

// 2. Configuración del generador del cliente de Prisma
generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  USER      // Usuario gratuito estándar
  PAID_USER // Usuario pago (Pro)
  ADMIN     // Administrador
}

enum TipoUsuario {
  SERVIDOR_PUBLICO
  ASESOR_PRIVADO
}

enum EstatusNormativaGIRS {
  VIGENTE
  EN_MORA
  EN_REVISION
}

enum EstadoCuenta {
  POR_ACTIVAR
  PRUEBA_GRATUITA
  ACTIVO
  SUSPENDIDO
  POR_PAGAR
  POR_RENOVAR
  SUSCRITO
}

// Etiquetas CRM para seguimiento administrativo de usuarios
enum EtiquetaCrm {
  // Compartidas (aplican a ambos tipos de usuario)
  POR_CONTACTAR       // Pendiente de contacto inicial
  CONTACTADO          // Ya fue contactado

  // Asesor Privado
  PAGO_REALIZADO      // El usuario ya realizó el pago

  // Servidor Público (el pago es un documento enviado a marketing)
  POR_ENVIAR_DOC          // Falta enviar documentación a marketing
  ENVIO_DOC               // Documentación ya fue enviada
  NO_TIENE_DOC            // El usuario no posee documentación
  NO_ENVIO_DOC_PLANIFICAR // No envió doc, planificar con ejecutivos hasta confirmar
}

// 3. --- Definición de tus Modelos (Tablas) ---

model User {
  id                String    @id @default(uuid())
  email             String    @unique
  password          String
  nombre            String
  apellido          String?
  role              UserRole  @default(USER)
  
  // Auth & Verification
  hashedRefreshToken String?
  confirmationToken  String?   @unique
  isEmailVerified    Boolean   @default(false)
  isActive           Boolean   @default(true)
  otp                String?
  otpExpiresAt       DateTime?

  telefono          String?   // AÑADIDO
  estado            String?
  municipio         String?
  tipoUsuario       TipoUsuario? @map("tipo_usuario")

  // Ciclo de Vida y Suscripciones
  estadoCuenta            EstadoCuenta @default(POR_ACTIVAR) @map("estado_cuenta")
  fechaVencimientoAcceso  DateTime?    @map("fecha_vencimiento_acceso")
  documentacionValidada   Boolean      @default(false) @map("documentacion_validada")
  pagoRealizado           Boolean      @default(false) @map("pago_realizado")

  createdAt         DateTime  @default(now()) @map("created_at") // AÑADIDO
  updatedAt         DateTime  @updatedAt @map("updated_at")

  // Relaciones
  profile     UserProfile? 
  profileCompleted Boolean @default(false)
  chatHistory ChatHistory[] // Un usuario puede tener muchos historiales de chat
  crmNotes    CrmNote[]     // Notas dejadas por administradores
}

model UserProfile {
  id               String  @id @default(uuid())
  nombreEnte       String  @map("nombre_ente")
  cargo            String?
  plazoEntregaActa String? @map("plazo_entrega_acta")
  estatusNormativaGirs EstatusNormativaGIRS? @map("estatus_normativa_girs")

  // Relación uno a uno con el usuario
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String @unique // La llave foránea
}



model ChatHistory {
  id          String   @id @default(uuid())
  sessionId   String   @map("session_id")
  userMessage String   @db.Text
  botResponse String   @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  // Relación con el usuario
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String
}

model TokenDenylist {
  id     String   @id @default(uuid())
  token  String   @db.Text
  expiry DateTime
}

model CrmNote {
  id          String        @id @default(uuid())
  content     String        @db.Text
  etiqueta    EtiquetaCrm?  // Etiqueta opcional para clasificar la nota
  adminId     String        @map("admin_id")     // ID del admin que la creó (sin FK estricta)
  adminNombre String        @map("admin_nombre") // Nombre del admin como respaldo
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt           @map("updated_at")

  // Relación con el usuario cliente al que pertenece la nota
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String @map("user_id")
}